# ============================================================
# Nasiko HR Automation Platform - Environment Configuration
# ============================================================

# Application
APP_NAME=nasiko-hr-platform
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-secret-in-production
APP_DEBUG=true

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./hr_platform.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/hr_platform

# LLM Provider - Using Groq (free) with Llama 3.3 70B (open source)
# Get your free API key at: https://console.groq.com/keys
# Groq provides blazing-fast inference for open-source models
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=your-groq-api-key-here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# Alternative models on Groq (uncomment to switch):
# LLM_MODEL=llama-3.1-8b-instant        # Faster, lighter
# LLM_MODEL=mixtral-8x7b-32768          # Good for long context

# Vector Store (ChromaDB)
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=hr_knowledge_base

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small

# JWT Auth
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=HR Platform

# Redis (optional, for caching/sessions)
REDIS_URL=redis://localhost:6379/0

# Nasiko Deployment
# TODO: Fill these with Nasiko-specific deployment values
NASIKO_AGENT_ID=hr-automation-agent
NASIKO_API_ENDPOINT=https://api.nasiko.ai
NASIKO_AGENT_TOKEN=your-nasiko-token
